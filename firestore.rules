rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role 
        : 'student';
    }
    
    function isAdmin() {
      let role = getUserRole();
      return role == 'admin' || role == 'super_admin';
    }

    function isTeacher() {
      let role = getUserRole();
      return role == 'teacher';
    }

    // 1. USERS COLLECTION
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Users can update their own document, BUT they cannot change their role. 
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == userId && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])))
      );
      allow delete: if isAuthenticated() && isAdmin();
    }

    // 2. TEACHER/ADMIN ONLY WRITE COLLECTIONS
    match /tests/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isTeacher());
    }
    match /classes/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isTeacher());
    }
    match /study_plans/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isTeacher());
    }
    match /shared_resources/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isTeacher());
    }
    match /mini_quizzes/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isTeacher());
    }
    match /feature_toggles/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isTeacher());
    }
    match /ebooks/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    // 3. PRICING (Admin only write)
    match /pricing/{planId} {
      allow read: if true; 
      allow write: if isAuthenticated() && isAdmin();
    }

    // 4. EVERYTHING ELSE (Results, logs, bookmarks, messages, etc)
    // For maximum safety to not break the app, we allow authenticated read/write.
    match /results/{document=**} { allow read, write: if isAuthenticated(); }
    match /test_assignments/{document=**} { allow read, write: if isAuthenticated(); }
    match /notifications/{document=**} { allow read, write: if isAuthenticated(); }
    match /test_access/{document=**} { allow read, write: if isAuthenticated(); }
    match /bookmarks/{document=**} { allow read, write: if isAuthenticated(); }
    match /activity_logs/{document=**} { allow read, write: if isAuthenticated(); }
    match /flashcard_sets/{document=**} { allow read, write: if isAuthenticated(); }
    match /vocabulary/{document=**} { allow read, write: if isAuthenticated(); }
    match /support_tickets/{document=**} { allow read, write: if isAuthenticated(); }
    match /conversations/{document=**} { allow read, write: if isAuthenticated(); }
    match /test_schedules/{document=**} { allow read, write: if isAuthenticated(); }

  }
}
